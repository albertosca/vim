" UN-001 a UN-004: vim_ai_autocomplete#ResolveProvider() -- logica pura,
" mesma decisao (Gemini padrao, Claude via toggle) ja usada no lado Neovim
" (nvim/lua/user/minuet_provider.lua).

Execute (UN-001 ResolveProvider: as duas keys presentes -> gemini, sem aviso):
  let [provider, level, message] = vim_ai_autocomplete#ResolveProvider(1, 1)
  AssertEqual 'gemini', provider
  AssertEqual v:null, level
  AssertEqual v:null, message

Execute (UN-002 ResolveProvider: so gemini presente -> gemini, com aviso):
  let [provider, level, message] = vim_ai_autocomplete#ResolveProvider(1, 0)
  AssertEqual 'gemini', provider
  AssertEqual 'warn', level
  Assert message =~# 'gemini', 'mensagem deveria mencionar gemini'

Execute (UN-003 ResolveProvider: so claude presente -> claude, com aviso):
  let [provider, level, message] = vim_ai_autocomplete#ResolveProvider(0, 1)
  AssertEqual 'claude', provider
  AssertEqual 'warn', level
  Assert message =~# 'claude', 'mensagem deveria mencionar claude'

Execute (UN-004 ResolveProvider: nenhuma key presente -> erro, sem provider):
  let [provider, level, message] = vim_ai_autocomplete#ResolveProvider(0, 0)
  AssertEqual v:null, provider
  AssertEqual 'error', level
  Assert message =~# 'GEMINI_API_KEY', 'mensagem deveria mencionar GEMINI_API_KEY'
  Assert message =~# 'ANTHROPIC_API_KEY', 'mensagem deveria mencionar ANTHROPIC_API_KEY'

" UN-005 a UN-010: contexto, montagem de request, parsing de resposta.
" Nenhum destes testes faz chamada de rede real -- so as funcoes puras.

Execute (UN-005 BuildContext: sem truncar quando cabe no teto):
  let ctx = vim_ai_autocomplete#BuildContext(['abc'], ['def'], 100)
  AssertEqual 'abc', ctx.before
  AssertEqual 'def', ctx.after

Execute (UN-006 BuildContext: trunca respeitando 75/25 quando excede o teto):
  let long_before = repeat('x', 100)
  let ctx = vim_ai_autocomplete#BuildContext(split(long_before, '\zs'), ['y'], 40)
  AssertEqual 30, strchars(ctx.before)
  AssertEqual 1, strchars(ctx.after)

Execute (UN-007 BuildGeminiRequest: produz JSON valido com o prompt):
  let req = vim_ai_autocomplete#BuildGeminiRequest({'before': 'def foo(', 'after': ')'})
  let decoded = json_decode(req)
  Assert decoded.contents[0].parts[0].text =~# 'def foo(', 'request deveria conter o contexto'

Execute (UN-008 BuildClaudeRequest: produz JSON valido com o model certo):
  let req = vim_ai_autocomplete#BuildClaudeRequest({'before': 'def foo(', 'after': ')'}, 'claude-sonnet-4-5-20250929')
  let decoded = json_decode(req)
  AssertEqual 'claude-sonnet-4-5-20250929', decoded.model
  Assert decoded.messages[0].content =~# 'def foo(', 'request deveria conter o contexto'

Execute (UN-009 ParseGeminiResponse: extrai as linhas do formato real da API):
  let fake = json_encode({'candidates': [{'content': {'parts': [{'text': "linha1\nlinha2"}]}}]})
  AssertEqual ['linha1', 'linha2'], vim_ai_autocomplete#ParseGeminiResponse(fake)

Execute (UN-010 ParseClaudeResponse: extrai as linhas do formato real da API):
  let fake = json_encode({'content': [{'text': "linhaA\nlinhaB\nlinhaC"}]})
  AssertEqual ['linhaA', 'linhaB', 'linhaC'], vim_ai_autocomplete#ParseClaudeResponse(fake)

" UN-011 a UN-015: ShowSuggestion/ClearSuggestion/IsVisible -- introspeccao
" via prop_list(), sem depender de tela/renderizacao visual de verdade.

Execute (UN-011 ShowSuggestion desenha 1 prop por linha da sugestao):
  new
  call setline(1, 'def foo(')
  call cursor(1, 9)
  call vim_ai_autocomplete#ShowSuggestion(['a, b):', '    return a + b'])
  AssertEqual 2, len(prop_list(1))
  AssertEqual 'def foo(', getline(1)
  call vim_ai_autocomplete#ClearSuggestion()
After:
  bdelete!

Execute (UN-012 ShowSuggestion nao altera o conteudo real do buffer):
  new
  call setline(1, 'def foo(')
  call cursor(1, 9)
  call vim_ai_autocomplete#ShowSuggestion(['a, b):'])
  AssertEqual 'def foo(', getline(1)
  call vim_ai_autocomplete#ClearSuggestion()
After:
  bdelete!

Execute (UN-013 IsVisible reflete o estado real):
  new
  call setline(1, 'x')
  call cursor(1, 2)
  AssertEqual 0, vim_ai_autocomplete#IsVisible()
  call vim_ai_autocomplete#ShowSuggestion(['y'])
  AssertEqual 1, vim_ai_autocomplete#IsVisible()
  call vim_ai_autocomplete#ClearSuggestion()
  AssertEqual 0, vim_ai_autocomplete#IsVisible()
After:
  bdelete!

Execute (UN-014 ClearSuggestion remove TODAS as props da linha, nao so uma):
  new
  call setline(1, 'x')
  call cursor(1, 2)
  call vim_ai_autocomplete#ShowSuggestion(['linha1', 'linha2', 'linha3'])
  AssertEqual 3, len(prop_list(1)), 'deveria ter 3 props (1 por linha da sugestao)'
  call vim_ai_autocomplete#ClearSuggestion()
  AssertEqual 0, len(prop_list(1)), 'ClearSuggestion deveria remover TODAS, nao so a primeira'
After:
  bdelete!

Execute (UN-015 ClearSuggestion usa a linha salva, nao a posicao atual do cursor):
  new
  call setline(1, ['linha um', 'linha dois'])
  call cursor(1, 1)
  call vim_ai_autocomplete#ShowSuggestion(['sugestao'])
  AssertEqual 1, len(prop_list(1))
  " simula o cursor tendo se movido (CursorMovedI dispara DEPOIS do movimento)
  call cursor(2, 1)
  call vim_ai_autocomplete#ClearSuggestion()
  AssertEqual 0, len(prop_list(1)), 'deveria limpar a linha 1 (onde a sugestao estava), nao a linha 2 (onde o cursor esta agora)'
After:
  bdelete!
