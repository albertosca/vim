# Persistent undo files (managed by Vim, cleaned automatically after 90 days)
temp_dirs/undodir/*
!temp_dirs/undodir/.gitignore
!temp_dirs/undodir/README.md

# Idem, formato de undo do Neovim (incompatível com o do Vim — dir separado)
temp_dirs/undodir-nvim/*

# OS
.DS_Store

# Erlang/Elixir crash dumps
erl_crash.dump
**/erl_crash.dump

# Tags
tags

# Database queries (may contain connection strings with passwords)
db_queries/

# copilot-chat.vim runtime data (OAuth device + chat tokens)
copilot-chat/

# Test isolation
test/xdg/
test/node/node_modules/

# Superpowers skills (infra local de Claude Code)
docs/superpowers/

# Customizações locais do usuário (ver my_configs.vim.example, que É versionado)
my_configs.vim
my_configs/
